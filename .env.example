# Telegram Bot token from @BotFather
BOT_TOKEN=your_telegram_bot_token_here

# Your Telegram user id (get it from @userinfobot). Comma-separated for multiple admins.
ADMIN_ID=your_telegram_admin_id_here

# Telegram Payments provider token (leave empty to use built-in demo payment mode)
PAYMENT_PROVIDER_TOKEN=

# Currency used for invoices (ISO 4217). Used by Telegram Payments.
CURRENCY=RUB

# Path to the SQLite database file
DATABASE_PATH=vpn_bot.db

# --- WireGuard auto-provisioning over SSH (optional) ---
# When enabled, the bot connects to each WireGuard server (by its host) over SSH
# and registers a real peer so issued keys work immediately. Set up the server
# first with install_vpn.sh, then add it in the admin panel using the printed
# public key / host / port.
WG_AUTO_PROVISION=false
# SSH user with sudo/root on the VPN servers
WG_SSH_USER=root
WG_SSH_PORT=22
# Provide EITHER a private key file path OR a password
WG_SSH_KEY=
WG_SSH_PASSWORD=
# Must match install_vpn.sh settings
WG_INTERFACE=wg0
WG_SUBNET=10.66.66.0/24
WG_DNS=1.1.1.1, 8.8.8.8

# --- 3X-UI panel provisioning (optional) ---
# Panels are added directly from the admin panel ("➕ Добавить 3X-UI панель"),
# no env config is required. These only tune defaults for all panels:
# Default VLESS flow applied to reality inbounds (cleared automatically for tls/ws/grpc)
XUI_FLOW=xtls-rprx-vision
# Verify TLS certificates when talking to panels over https (set true for valid certs)
XUI_VERIFY_SSL=false
